# D-GITALCODE ExtractorX — optional environment overrides
# Copy to .env for local development (never commit .env)

# Override default output parent directory (settings.json takes precedence in GUI)
# EXTRACTORX_OUTPUT_DIR=C:\Users\you\Documents\ExtractorX\output

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# EXTRACTORX_LOG_LEVEL=INFO
